# qPKI Deployment Configuration Template
# Copy this file to config/deployment.conf and customize for your environment

# Domain Configuration
QPKI_DOMAIN=localhost
QPKI_EMAIL=admin@yourdomain.com

# Installation Paths
QPKI_HOME=/opt/qpki
QPKI_USER=qpki
QPKI_GROUP=qpki

# Application Settings
WEB_PORT=9090
SSL_ENABLED=true

# Database Configuration
DB_TYPE=sqlite  # sqlite or postgresql
DB_NAME=qpki
DB_USER=qpki_user
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# SSL Certificate Options
SSL_TYPE=self-signed  # self-signed or letsencrypt
SSL_DIR=/etc/ssl/qpki

# Email/SMTP Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@domain.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=qpki@yourdomain.com

# Security Settings
ENABLE_FIREWALL=true
ENABLE_FAIL2BAN=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_DIR=/opt/qpki/backups
BACKUP_RETENTION_DAYS=30
